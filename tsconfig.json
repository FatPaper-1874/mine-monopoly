{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"jsx": "preserve",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@G/*": ["./*"],
			"@mine-monopoly/types": ["./packages/types/index.ts"],
			"@mine-monopoly/types/*": ["./packages/types/*"],
			"@mine-monopoly/env": ["./packages/env/src/browser.ts"],
			"@mine-monopoly/utils": ["./packages/utils/src/index.ts"]
		},
		"resolveJsonModule": true,

		"types": ["node", "vite/client"],
		"noEmit": true,
		"lib": ["ESNext", "DOM"]
	},
	"include": ["apps/**/*", "packages/**/*"],
	"exclude": ["node_modules", "dist", "**/*.test.ts"]
}
